# Copie para .env e preencha localmente. Nunca commitar .env com valores reais.

# --- packages/database ---
DATABASE_URL="postgresql://clube:clube@localhost:5432/clube_da_esquerda?schema=public"

# --- apps/api ---
PORT=3333
NODE_ENV=development
# Origem pública da própria API — usada para montar URLs absolutas de
# arquivos enviados via POST /uploads (ex.: http://localhost:3333 em
# dev, https://api.clubedaesquerda.org em produção).
API_PUBLIC_URL="http://localhost:3333"

# Segredo usado no HMAC-SHA256 do CPF (nunca reaproveitar de outro contexto).
# Ver docs/contexto.md secao 2.
CPF_PEPPER="troque-por-um-segredo-forte-gerado-em-producao"

# Par de chaves RS256 para assinatura do access token JWT (PEM base64).
JWT_ACCESS_PRIVATE_KEY=""
JWT_ACCESS_PUBLIC_KEY=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Chave de envelope encryption (KMS) para cpfEncrypted, quando aplicavel.
CPF_KMS_KEY_ID=""

REDIS_URL="redis://localhost:6379"

# E-mail transacional via API HTTP do Resend (verificação de e-mail).
# MAIL_FROM precisa usar um domínio verificado no Resend.
RESEND_API_KEY=""
MAIL_FROM="Clube da Esquerda <no-reply@vintagedevstack.com.br>"

# Origem do frontend, usada em CORS e nos links dos e-mails transacionais.
WEB_ORIGIN="http://localhost:3000"

# SMTP para envio de e-mail transacional (verificação de cadastro).
# Em dev, aponte para o Maildev/Mailtrap local (ex.: maildev na porta 1025).
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Clube da Esquerda <no-reply@clubedaesquerda.org>"

# Chave da API do Tenor para busca de GIFs no chat (GET /gifs/search).
# Sem chave, a busca de GIF fica indisponível mas o resto do chat segue
# funcionando normalmente — ver docs/contexto.md.
TENOR_API_KEY=""

# --- apps/web ---
NEXT_PUBLIC_API_URL="http://localhost:3333"
NEXT_PUBLIC_WS_URL="ws://localhost:3333"
